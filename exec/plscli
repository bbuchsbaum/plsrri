#!/usr/bin/env Rscript

args <- commandArgs(trailingOnly = TRUE)

find_repo_root <- function() {
  roots <- unique(c(
    getwd(),
    dirname(getwd()),
    dirname(dirname(getwd()))
  ))

  for (root in roots) {
    if (file.exists(file.path(root, "DESCRIPTION")) &&
        file.exists(file.path(root, "R", "plscli.R"))) {
      return(normalizePath(root, winslash = "/", mustWork = TRUE))
    }
  }

  NA_character_
}

status <- tryCatch(
  {
    if (!requireNamespace("plsrri", quietly = TRUE)) {
      repo_root <- find_repo_root()
      if (is.na(repo_root)) {
        stop("Package 'plsrri' is not installed and no source checkout was found", call. = FALSE)
      }
      if (requireNamespace("pkgload", quietly = TRUE)) {
        pkgload::load_all(repo_root, export_all = FALSE, helpers = FALSE, quiet = TRUE)
      } else if (requireNamespace("devtools", quietly = TRUE)) {
        devtools::load_all(repo_root, export_all = FALSE, helpers = FALSE, quiet = TRUE)
      } else {
        stop("Install 'plsrri' or make 'pkgload'/'devtools' available for source-checkout execution", call. = FALSE)
      }
    }

    plsrri::plscli_main(args)
  },
  error = function(e) {
    message("plsrri: ", conditionMessage(e))
    2L
  }
)

quit(save = "no", status = as.integer(status))
